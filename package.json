{
  "name": "dev-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.14.0",
  "scripts": {
    "gen:openapi": "node scripts/build/generate-openapi.mjs",
    "predev": "node scripts/build/generate-openapi.mjs && prisma generate",
    "prebuild": "node scripts/build/generate-openapi.mjs && prisma generate",
    "dev": "next dev",
    "build": "next build --webpack",
    "build:prod": "node scripts/build/generate-openapi.mjs && prisma generate && BUILD_DIR=.next-prod next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "cleanup:apifox-logs": "node scripts/ops/cleanup-apifox-logs.mjs",
    "docker:build:server": "rm -rf .next-prod && pnpm build:prod && docker buildx build --platform linux/amd64 --load -t dev-portal:latest .",
    "docker:save": "mkdir -p artifacts/docker && docker save -o artifacts/docker/dev-portal.tar dev-portal:latest",
    "docker:pack": "pnpm docker:build:server && pnpm docker:save",
    "docker:dev": "docker compose up -d --build",
    "docker:stop": "docker compose down",
    "extension:pack": "node scripts/build/pack-extension.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@prisma/client": "^5.22.0",
    "antd": "^6.1.4",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "kbar": "^0.1.0-beta.48",
    "next": "16.1.1",
    "next-swagger-doc": "^0.4.1",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swagger-ui-react": "^5.31.0",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitepress": "^1.6.4"
  }
}
